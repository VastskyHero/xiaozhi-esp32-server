# =============================================================================
# IntiCore Qwen3TTS 沪语（上海话）Provider 配置示例
# =============================================================================
# 用法：复制此文件到 data/.config.yaml，替换 api_key，然后重启服务。
#
# 方案 1A：WebSocket 实时流式（优先，低延迟）
# =============================================================================

selected_module:
  TTS: Qwen3TTS

TTS:
  Qwen3TTS:
    # ── 必填 ──────────────────────────────────────────────────────────
    type: qwen3_tts                    # Provider 类型（对应 qwen3_tts.py）
    api_key: "你的阿里百炼API密钥"      # https://bailian.console.aliyun.com/

    # ── 模型 & 音色 ──────────────────────────────────────────────────
    model: "qwen3-tts-flash-realtime"  # WebSocket 实时流式模型
    voice: "Jada"                      # 上海-阿珍（原生沪语/吴语发音）
    mode: "server_commit"              # 服务端自动判断合成时机
    language_type: "Chinese"           # 输入语言类型

    # ── 音频参数 ─────────────────────────────────────────────────────
    format: pcm                        # 原始 PCM（由 Provider 编码为 Opus）
    sample_rate: 24000                 # 采样率（与 ESP32 一致）
    rate: 0.9                          # 语速（老年用户偏慢）
    volume: 50                         # 音量 (0-100)

    # ── 其他 ─────────────────────────────────────────────────────────
    output_dir: tmp/                   # 临时文件目录
    tts_timeout: 15                    # TTS 超时时间（秒）

# =============================================================================
# 方案 1B：HTTP 非流式（备选，仅当 1A WebSocket 遇阻时启用）
# =============================================================================
#
# selected_module:
#   TTS: Qwen3TTS
#
# TTS:
#   Qwen3TTS:
#     type: qwen3_tts
#     api_key: "你的阿里百炼API密钥"
#     model: "qwen3-tts-flash-2025-11-27"    # HTTP 非流式模型
#     voice: "Jada"
#     language_type: "Chinese"
#     format: wav
#     sample_rate: 24000
#     rate: 0.9
#     output_dir: tmp/
#
# =============================================================================
# 方言音色参考（Qwen3-TTS 内置 49 个系统音色中的方言专用音色）
# =============================================================================
# 上海话（吴语）: Jada   (上海-阿珍)  ← IntiCore 首选
# 北京话:         Dylan  (北京-晓东)
# 南京话:         Li     (南京-老李)
# 陕西话:         Marcus (陕西-秦川)
# 闽南话:         Roy    (闽南-阿杰)
# 天津话:         Peter  (天津-李彼得)
# 四川话（女）:   Sunny  (四川-晴儿)
# 四川话（男）:   Eric   (四川-程川)
# 粤语（男）:     Rocky  (粤语-阿强)
# 粤语（女）:     Kiki   (粤语-阿清)
# =============================================================================
